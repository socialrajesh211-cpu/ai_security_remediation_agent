# ============================================================================
# 1. ALWAYS REQUIRED — the server refuses to boot (env.ts fails fast) without these.
# ============================================================================

# The only var with no default anywhere in env.ts. Every model (User, Finding,
# DemoUser, DemoSession, Preference) needs a live connection.
MONGODB_URI=mongodb://localhost:27017/ai-security-remediation-agent

# Required in production only (env.ts's superRefine enforces this) — encrypts
# stored GitHub access tokens at rest. In development, if left blank, tokens
# are stored in plaintext as a local-only fallback (see utils/crypto.ts).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# ============================================================================
# 2. REQUIRED FOR THE CORE APP — GitHub OAuth is the primary (non-demo) login
# path. Technically the server still boots without these (they default to
# ""), but GET /api/github/login returns 503 "GitHub OAuth is not configured"
# until they're set — so in practice this is required.
# ============================================================================
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/github/callback

# ============================================================================
# 3. REQUIRED FOR AI FEATURES — /api/ai/analyze, /patch, /pull-request all 502
# with AI_NOT_CONFIGURED until the key matching AI_PROVIDER below is set. Only
# the one matching provider actually needs a key; the other two can stay blank.
# ============================================================================
AI_PROVIDER=claude
AI_TIMEOUT_MS=30000

ANTHROPIC_API_KEY=your_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ============================================================================
# 4. OPTIONAL — Demo Mode. All-or-nothing: the feature quietly stays disabled
# (GET /api/auth/google/login returns 503) unless every single one of these
# is set. Safe to leave blank if you don't want "Try Demo" enabled.
# ============================================================================
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# A GitHub Fine-Grained PAT scoped to ONLY the one repo below
# (Contents + Pull requests: Read and write). NEVER sent to the browser — the
# server injects it server-side once a demo session is resolved.
DEMO_GITHUB_TOKEN=
DEMO_REPO_OWNER=
DEMO_REPO_NAME=
DEMO_SESSION_TTL_HOURS=24

# ============================================================================
# 5. OPTIONAL — local dev convenience only. Ignored in production regardless
# of value (see auth.middleware.ts) — never a substitute for real OAuth.
# ============================================================================
GITHUB_TOKEN=

# ============================================================================
# 6. OPTIONAL — deployment/tuning knobs. Sensible defaults exist for all of
# these in env.ts; only touch them if you know you need to.
# ============================================================================
EXTRA_CORS_ORIGINS=
TRUST_PROXY=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AI_RATE_LIMIT_MAX=30
